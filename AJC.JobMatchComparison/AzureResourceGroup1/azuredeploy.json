{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "type": "string",
      "defaultValue": "dev",
      "allowedValues": [
        "dev",
        "qa",
        "prod"
      ],
      "metadata": {
        "description": "Deployment environment."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for resources."
      }
    },
    "namePrefix": {
      "type": "string",
      "minLength": 3,
      "maxLength": 12,
      "metadata": {
        "description": "Lowercase letters and numbers only."
      }
    },
    "sqlAdministratorLogin": {
      "type": "string"
    },
    "sqlAdministratorPassword": {
      "type": "secureString",
      "metadata": {
        "description": "The administrator password of the SQL Server"
      }
    },
    "sqlEntraAdminObjectId": {
      "type": "string",
      "defaultValue": ""
    },
    "sqlEntraAdminLogin": {
      "type": "string",
      "defaultValue": "JobMatch SQL Administrators"
    },
    "sqlAllowedIpAddress": {
      "type": "string",
      "defaultValue": ""
    },
    "functionMaximumInstanceCount": {
      "type": "int",
      "defaultValue": 20,
      "minValue": 1,
      "maxValue": 1000
    },
    "functionInstanceMemoryMB": {
      "type": "int",
      "defaultValue": 2048,
      "allowedValues": [
        2048,
        4096
      ]
    },
    "roleAssignmentGeneration": {
      "type": "string",
      "defaultValue": "windows-v1",
      "metadata": {
        "description": "Stable seed used in role-assignment names. Change this value only when the Function App system-assigned identity is recreated."
      }
    },
    "openAiApiKey": {
      "type": "secureString",
      "metadata": {
        "description": "OpenAI API key. Supply during deployment; do not store it in a checked-in parameter file."
      }
    },
    "openAiModel": {
      "type": "string",
      "defaultValue": "gpt-5.6",
      "metadata": {
        "description": "Public OpenAI API model name used by the Function App."
      }
    }
  },
  "variables": {
    "suffix": "[toLower(format('{0}-{1}', parameters('namePrefix'), parameters('environmentName')))]",
    "compactSuffix": "[take(toLower(replace(format('{0}{1}', parameters('namePrefix'), parameters('environmentName')), '-', '')), 20)]",
    "tags": {
      "application": "JobMatchComparison",
      "environment": "[parameters('environmentName')]",
      "managedBy": "ARM"
    },
    "logAnalyticsName": "[format('{0}-logs', variables('suffix'))]",
    "applicationInsightsName": "[format('{0}-appi', variables('suffix'))]",
    "runtimeStorageName": "[take(format('{0}func', variables('compactSuffix')), 24)]",
    "applicationStorageName": "[take(format('{0}data', variables('compactSuffix')), 24)]",
    "serviceBusNamespaceName": "[format('{0}', variables('suffix'))]",
    "serviceBusQueueName": "job-analysis",
    "sqlServerName": "[take(format('{0}-{1}-sql', 'ajc', variables('compactSuffix')), 63)]",
    "sqlDatabaseName": "JobMatchComparison",
    "keyVaultName": "[concat('ajc-keyvault3', '-', parameters('environmentName'))]",
    "operationsKeyVaultName": "[concat('ajc-ops-keyvault3', '-', parameters('environmentName'))]",
    "sqlAdministratorPasswordSecretName": "Sql-Administrator-Password",
    "functionPlanName": "[format('{0}-flex-plan', variables('suffix'))]",
    "functionAppName": "[concat('ajc-functionapp', '-', parameters('environmentName'))]",
    "deploymentContainerName": "function-releases",
    "storageBlobDataContributorRoleId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', 'ba92f5b4-2d11-453d-a403-e96b0029c9fe')]",
    "storageQueueDataContributorRoleId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '974c5e8b-45b9-4653-ba55-5f855dd0fb88')]",
    "storageTableDataContributorRoleId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '0a9a7e1f-b9d0-4cc4-a60d-0319b160aaa3')]",
    "serviceBusDataReceiverRoleId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '4f6d3b9b-027b-4f4c-9142-0e5a2a2247e0')]",
    "serviceBusDataSenderRoleId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '69a216fc-b8fb-44d8-bc22-1f3c2cd27a39')]",
    "keyVaultSecretsUserRoleId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '4633458b-17de-408a-b874-0445c86b69e6')]"
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2023-09-01",
      "name": "[variables('logAnalyticsName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 30
      },
      "dependsOn": []
    },
    {
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[variables('applicationInsightsName')]",
      "location": "[parameters('location')]",
      "kind": "web",
      "tags": "[variables('tags')]",
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName'))]"
      ],
      "properties": {
        "Application_Type": "web",
        "WorkspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName'))]",
        "IngestionMode": "LogAnalytics",
        "publicNetworkAccessForIngestion": "Enabled",
        "publicNetworkAccessForQuery": "Enabled"
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-05-01",
      "name": "[variables('runtimeStorageName')]",
      "location": "[parameters('location')]",
      "kind": "StorageV2",
      "sku": {
        "name": "Standard_LRS"
      },
      "tags": "[variables('tags')]",
      "properties": {
        "allowBlobPublicAccess": false,
        "allowSharedKeyAccess": true,
        "defaultToOAuthAuthentication": true,
        "minimumTlsVersion": "TLS1_2",
        "supportsHttpsTrafficOnly": true,
        "publicNetworkAccess": "Enabled"
      },
      "dependsOn": []
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/default', variables('runtimeStorageName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', variables('runtimeStorageName'))]"
      ],
      "properties": {
        "deleteRetentionPolicy": {
          "enabled": true,
          "days": 7
        }
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/default/{1}', variables('runtimeStorageName'), variables('deploymentContainerName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/blobServices', variables('runtimeStorageName'), 'default')]"
      ],
      "properties": {
        "publicAccess": "None"
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-05-01",
      "name": "[variables('applicationStorageName')]",
      "location": "[parameters('location')]",
      "kind": "StorageV2",
      "sku": {
        "name": "Standard_LRS"
      },
      "tags": "[variables('tags')]",
      "properties": {
        "allowBlobPublicAccess": false,
        "allowSharedKeyAccess": false,
        "defaultToOAuthAuthentication": true,
        "minimumTlsVersion": "TLS1_2",
        "supportsHttpsTrafficOnly": true,
        "publicNetworkAccess": "Enabled"
      },
      "dependsOn": []
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/default', variables('applicationStorageName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', variables('applicationStorageName'))]"
      ],
      "properties": {
        "deleteRetentionPolicy": {
          "enabled": true,
          "days": 14
        }
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/default/raw-job-postings', variables('applicationStorageName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/blobServices', variables('applicationStorageName'), 'default')]"
      ],
      "properties": {
        "publicAccess": "None"
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/default/normalized-job-postings', variables('applicationStorageName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/blobServices', variables('applicationStorageName'), 'default')]"
      ],
      "properties": {
        "publicAccess": "None"
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/default/processing-failures', variables('applicationStorageName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/blobServices', variables('applicationStorageName'), 'default')]"
      ],
      "properties": {
        "publicAccess": "None"
      }
    },
    {
      "type": "Microsoft.ServiceBus/namespaces",
      "apiVersion": "2024-01-01",
      "name": "[variables('serviceBusNamespaceName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard",
        "tier": "Standard"
      },
      "tags": "[variables('tags')]",
      "properties": {
        "minimumTlsVersion": "1.2",
        "publicNetworkAccess": "Enabled",
        "disableLocalAuth": true
      },
      "dependsOn": []
    },
    {
      "type": "Microsoft.ServiceBus/namespaces/queues",
      "apiVersion": "2024-01-01",
      "name": "[format('{0}/{1}', variables('serviceBusNamespaceName'), variables('serviceBusQueueName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.ServiceBus/namespaces', variables('serviceBusNamespaceName'))]"
      ],
      "properties": {
        "lockDuration": "PT5M",
        "maxDeliveryCount": 10,
        "deadLetteringOnMessageExpiration": true,
        "defaultMessageTimeToLive": "P14D",
        "enablePartitioning": true,
        "requiresDuplicateDetection": true,
        "duplicateDetectionHistoryTimeWindow": "PT10M"
      }
    },
    {
      "type": "Microsoft.Sql/servers",
      "apiVersion": "2023-08-01-preview",
      "name": "[variables('sqlServerName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]",
      "properties": {
        "administratorLogin": "[parameters('sqlAdministratorLogin')]",
        "administratorLoginPassword": "[parameters('sqlAdministratorPassword')]",
        "minimalTlsVersion": "1.2",
        "publicNetworkAccess": "Enabled",
        "restrictOutboundNetworkAccess": "Disabled"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults/secrets', variables('operationsKeyVaultName'), variables('sqlAdministratorPasswordSecretName'))]"
      ]
    },
    {
      "type": "Microsoft.Sql/servers/databases",
      "apiVersion": "2023-08-01-preview",
      "name": "[format('{0}/{1}', variables('sqlServerName'), variables('sqlDatabaseName'))]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]",
      "dependsOn": [
        "[resourceId('Microsoft.Sql/servers', variables('sqlServerName'))]"
      ],
      "sku": {
        "name": "Basic",
        "tier": "Basic",
        "capacity": 5
      },
      "properties": {
        "maxSizeBytes": 2147483648,
        "zoneRedundant": false,
        "readScale": "Disabled"
      }
    },
    {
      "type": "Microsoft.Sql/servers/firewallRules",
      "apiVersion": "2023-08-01-preview",
      "name": "[format('{0}/AllowAzureServices', variables('sqlServerName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Sql/servers', variables('sqlServerName'))]"
      ],
      "properties": {
        "startIpAddress": "0.0.0.0",
        "endIpAddress": "0.0.0.0"
      }
    },
    {
      "condition": "[not(empty(parameters('sqlAllowedIpAddress')))]",
      "type": "Microsoft.Sql/servers/firewallRules",
      "apiVersion": "2023-08-01-preview",
      "name": "[format('{0}/DeploymentClient', variables('sqlServerName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Sql/servers', variables('sqlServerName'))]"
      ],
      "properties": {
        "startIpAddress": "[parameters('sqlAllowedIpAddress')]",
        "endIpAddress": "[parameters('sqlAllowedIpAddress')]"
      }
    },
    {
      "condition": "[not(empty(parameters('sqlEntraAdminObjectId')))]",
      "type": "Microsoft.Sql/servers/administrators",
      "apiVersion": "2023-08-01-preview",
      "name": "[format('{0}/ActiveDirectory', variables('sqlServerName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Sql/servers', variables('sqlServerName'))]"
      ],
      "properties": {
        "administratorType": "ActiveDirectory",
        "login": "[parameters('sqlEntraAdminLogin')]",
        "sid": "[parameters('sqlEntraAdminObjectId')]",
        "tenantId": "[subscription().tenantId]",
        "azureADOnlyAuthentication": false
      }
    },
    {
      "type": "Microsoft.KeyVault/vaults",
      "apiVersion": "2023-07-01",
      "name": "[variables('keyVaultName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]",
      "properties": {
        "tenantId": "[subscription().tenantId]",
        "sku": {
          "family": "A",
          "name": "standard"
        },
        "enableRbacAuthorization": true,
        "enabledForDeployment": false,
        "enabledForDiskEncryption": false,
        "enabledForTemplateDeployment": false,
        "enablePurgeProtection": true,
        "softDeleteRetentionInDays": 90,
        "publicNetworkAccess": "Enabled"
      },
      "dependsOn": []
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', variables('keyVaultName'), 'OpenAI-ApiKey')]",
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName'))]"
      ],
      "properties": {
        "value": "[parameters('openAiApiKey')]",
        "contentType": "OpenAI API key",
        "attributes": {
          "enabled": true
        }
      }
    },
    {
      "type": "Microsoft.KeyVault/vaults",
      "apiVersion": "2023-07-01",
      "name": "[variables('operationsKeyVaultName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]",
      "properties": {
        "tenantId": "[subscription().tenantId]",
        "sku": {
          "family": "A",
          "name": "standard"
        },
        "enableRbacAuthorization": true,
        "enabledForDeployment": false,
        "enabledForDiskEncryption": false,
        "enabledForTemplateDeployment": false,
        "enablePurgeProtection": true,
        "softDeleteRetentionInDays": 90,
        "publicNetworkAccess": "Enabled"
      },
      "dependsOn": []
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', variables('operationsKeyVaultName'), variables('sqlAdministratorPasswordSecretName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('operationsKeyVaultName'))]"
      ],
      "properties": {
        "value": "[parameters('sqlAdministratorPassword')]",
        "contentType": "Azure SQL administrator password",
        "attributes": {
          "enabled": true
        }
      }
    },
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2024-04-01",
      "name": "[variables('functionPlanName')]",
      "location": "[parameters('location')]",
      "kind": "functionapp",
      "tags": "[variables('tags')]",
      "sku": {
        "name": "Y1",
        "tier": "Dynamic"
      },
      "properties": {
        "reserved": false
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2024-04-01",
      "name": "[variables('functionAppName')]",
      "location": "[parameters('location')]",
      "kind": "functionapp",
      "tags": "[variables('tags')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('functionPlanName'))]",
        "[resourceId('Microsoft.Insights/components', variables('applicationInsightsName'))]",
        "[resourceId('Microsoft.ServiceBus/namespaces/queues', variables('serviceBusNamespaceName'), variables('serviceBusQueueName'))]",
        "[resourceId('Microsoft.Sql/servers/databases', variables('sqlServerName'), variables('sqlDatabaseName'))]",
        "[resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName'))]",
        "[resourceId('Microsoft.KeyVault/vaults/secrets', variables('keyVaultName'), 'OpenAI-ApiKey')]"
      ],
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('functionPlanName'))]",
        "httpsOnly": true,
        "publicNetworkAccess": "Enabled",
        "clientAffinityEnabled": false
      }
    },
    {
      "type": "Microsoft.Web/sites/config",
      "apiVersion": "2024-04-01",
      "name": "[format('{0}/web', variables('functionAppName'))]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', variables('functionAppName'))]"
      ],
      "properties": {
        "alwaysOn": false,
        "ftpsState": "Disabled",
        "minTlsVersion": "1.2",
        "http20Enabled": true,
        "netFrameworkVersion": "v8.0",
        "appSettings": [
          {
            "name": "FUNCTIONS_EXTENSION_VERSION",
            "value": "~4"
          },
          {
            "name": "FUNCTIONS_WORKER_RUNTIME",
            "value": "dotnet-isolated"
          },
          {
            "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
            "value": "[reference(resourceId('Microsoft.Insights/components', variables('applicationInsightsName')), '2020-02-02').ConnectionString]"
          },
          {
            "name": "AzureWebJobsStorage__accountName",
            "value": "[variables('runtimeStorageName')]"
          },
          {
            "name": "AzureWebJobsStorage__credential",
            "value": "managedidentity"
          },
          {
            "name": "JobMatchStorage__serviceUri",
            "value": "[reference(resourceId('Microsoft.Storage/storageAccounts', variables('applicationStorageName')), '2023-05-01').primaryEndpoints.blob]"
          },
          {
            "name": "JobMatchStorage__accountName",
            "value": "[variables('applicationStorageName')]"
          },
          {
            "name": "ServiceBus__fullyQualifiedNamespace",
            "value": "[format('{0}.servicebus.windows.net', variables('serviceBusNamespaceName'))]"
          },
          {
            "name": "ServiceBus__queueName",
            "value": "[variables('serviceBusQueueName')]"
          },
          {
            "name": "Sql__connectionString",
            "value": "[format('Server=tcp:{0},1433;Initial Catalog={1};Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;Authentication=Active Directory Managed Identity;', reference(resourceId('Microsoft.Sql/servers', variables('sqlServerName')), '2023-08-01-preview').fullyQualifiedDomainName, variables('sqlDatabaseName'))]"
          },
          {
            "name": "KeyVault__vaultUri",
            "value": "[reference(resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName')), '2023-07-01').vaultUri]"
          },
          {
            "name": "OpenAI__ApiKey",
            "value": "[format('@Microsoft.KeyVault(SecretUri=https://{0}.vault.azure.net/secrets/OpenAI-ApiKey/)', variables('keyVaultName'))]"
          },
          {
            "name": "OpenAI__Model",
            "value": "[parameters('openAiModel')]"
          }
        ],
        "use32BitWorkerProcess": false
      }
    },
    {
      "type": "Microsoft.Insights/diagnosticSettings",
      "apiVersion": "2021-05-01-preview",
      "scope": "[format('Microsoft.Web/sites/{0}', variables('functionAppName'))]",
      "name": "send-to-log-analytics",
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', variables('functionAppName'))]",
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName'))]"
      ],
      "properties": {
        "workspaceId": "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName'))]",
        "logs": [
          {
            "categoryGroup": "allLogs",
            "enabled": true
          }
        ],
        "metrics": [
          {
            "category": "AllMetrics",
            "enabled": true
          }
        ]
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/providers/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[format('{0}/Microsoft.Authorization/{1}', variables('runtimeStorageName'), guid(resourceId('Microsoft.Storage/storageAccounts', variables('runtimeStorageName')), variables('functionAppName'), parameters('roleAssignmentGeneration'), variables('storageBlobDataContributorRoleId')))]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', variables('functionAppName'))]",
        "[resourceId('Microsoft.Storage/storageAccounts', variables('runtimeStorageName'))]"
      ],
      "properties": {
        "principalId": "[reference(resourceId('Microsoft.Web/sites', variables('functionAppName')), '2024-04-01', 'Full').identity.principalId]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[variables('storageBlobDataContributorRoleId')]"
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/providers/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[format('{0}/Microsoft.Authorization/{1}', variables('runtimeStorageName'), guid(resourceId('Microsoft.Storage/storageAccounts', variables('runtimeStorageName')), variables('functionAppName'), parameters('roleAssignmentGeneration'), variables('storageQueueDataContributorRoleId')))]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', variables('functionAppName'))]",
        "[resourceId('Microsoft.Storage/storageAccounts', variables('runtimeStorageName'))]"
      ],
      "properties": {
        "principalId": "[reference(resourceId('Microsoft.Web/sites', variables('functionAppName')), '2024-04-01', 'Full').identity.principalId]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[variables('storageQueueDataContributorRoleId')]"
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/providers/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[format('{0}/Microsoft.Authorization/{1}', variables('runtimeStorageName'), guid(resourceId('Microsoft.Storage/storageAccounts', variables('runtimeStorageName')), variables('functionAppName'), parameters('roleAssignmentGeneration'), variables('storageTableDataContributorRoleId')))]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', variables('functionAppName'))]",
        "[resourceId('Microsoft.Storage/storageAccounts', variables('runtimeStorageName'))]"
      ],
      "properties": {
        "principalId": "[reference(resourceId('Microsoft.Web/sites', variables('functionAppName')), '2024-04-01', 'Full').identity.principalId]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[variables('storageTableDataContributorRoleId')]"
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/providers/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[format('{0}/Microsoft.Authorization/{1}', variables('applicationStorageName'), guid(resourceId('Microsoft.Storage/storageAccounts', variables('applicationStorageName')), variables('functionAppName'), parameters('roleAssignmentGeneration'), variables('storageBlobDataContributorRoleId')))]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', variables('functionAppName'))]",
        "[resourceId('Microsoft.Storage/storageAccounts', variables('applicationStorageName'))]"
      ],
      "properties": {
        "principalId": "[reference(resourceId('Microsoft.Web/sites', variables('functionAppName')), '2024-04-01', 'Full').identity.principalId]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[variables('storageBlobDataContributorRoleId')]"
      }
    },
    {
      "type": "Microsoft.ServiceBus/namespaces/providers/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[format('{0}/Microsoft.Authorization/{1}', variables('serviceBusNamespaceName'), guid(resourceId('Microsoft.ServiceBus/namespaces', variables('serviceBusNamespaceName')), variables('functionAppName'), parameters('roleAssignmentGeneration'), variables('serviceBusDataReceiverRoleId')))]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', variables('functionAppName'))]",
        "[resourceId('Microsoft.ServiceBus/namespaces', variables('serviceBusNamespaceName'))]"
      ],
      "properties": {
        "principalId": "[reference(resourceId('Microsoft.Web/sites', variables('functionAppName')), '2024-04-01', 'Full').identity.principalId]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[variables('serviceBusDataReceiverRoleId')]"
      }
    },
    {
      "type": "Microsoft.ServiceBus/namespaces/providers/roleAssignments",
      "apiVersion": "2022-04-01",
